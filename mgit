#!/usr/bin/env bb
(require '[babashka.fs :as fs]
         '[clojure.string :as str]
         '[cheshire.core :as json])
(import '[java.security MessageDigest]
        '[java.util.zip DeflaterOutputStream]
        '[java.io ByteArrayOutputStream]
        '[java.nio.charset StandardCharsets])

(def mgit-dir (fs/path ".mgit"))
(def objects-dir (fs/path mgit-dir "objects"))
(def refs-dir (fs/path mgit-dir "refs"))
(def heads-dir (fs/path refs-dir "heads"))
(def head-file (fs/path mgit-dir "HEAD"))
(def index-file (fs/path mgit-dir "index"))

(defn- eprintln [& args]
  (binding [*out* *err*]
    (apply println args)))

(defn- sha1 [data]
  (let [digest (MessageDigest/getInstance "SHA-1")]
    (.update digest (.getBytes data StandardCharsets/UTF_8))
    (let [hash-bytes (.digest digest)]
      (apply str (map #(format "%02x" %) hash-bytes)))))

(defn- zlib-compress [data]
  (let [boas (ByteArrayOutputStream.)]
    (with-open [dos (DeflaterOutputStream. boas)]
      (.write dos data))
    (.toByteArray boas)))

(defn- write-object [data]
  (let [hash (sha1 data)
        obj-path (fs/path objects-dir hash)]
    (when-not (fs/exists? obj-path)
      (fs/write-bytes obj-path (zlib-compress (.getBytes data StandardCharsets/UTF_8))))
    hash))

(defn- read-index []
  (if (fs/exists? index-file)
    (->> (fs/read-all-lines index-file)
         (remove str/blank?)
         (into {} (map #(let [[path hash] (str/split % #"\s+")]
                          [path hash]))))
    {}))

(defn- write-index [index]
  (fs/write-lines
   index-file
   (map (fn [[path hash]] (str path " " hash)) index)))

(defn- resolve-ref [ref]
  (-> ref
      (str/split #":" 2)
      second
      str/trim))

(defn- get-head-commit []
  (when (fs/exists? head-file)
    (let [ref (str/trim (slurp (str head-file)))]
      (if (str/starts-with? ref "ref:")
        (let [ref-path (fs/path mgit-dir (resolve-ref ref))]
          (if (fs/exists? ref-path)
            (str/trim (slurp (str ref-path)))
            ""))
        ref))))

(defn- get-current-branch []
  (let [ref (str/trim (slurp (str head-file)))]
    (if (str/starts-with? ref "ref:")
      (fs/file-name (resolve-ref ref))
      nil)))

(defmulti dispatch-command (fn [command _] command))

(defmethod dispatch-command :default
  [command _]
  (eprintln (str "Unknown command: " command))
  (System/exit 1))

(defmethod dispatch-command "init" [_ _]
  (if (fs/exists? mgit-dir)
    (println (str mgit-dir " already exists"))
    (do
      (doseq [path [mgit-dir objects-dir refs-dir heads-dir]]
        (fs/create-dirs path))
      (fs/write-lines head-file ["ref: refs/heads/master"])
      (fs/create-file index-file)
      (fs/create-file (fs/path heads-dir "master"))
      (println (str "Initialized empty mgit repository in " mgit-dir)))))

(defmethod dispatch-command "add" [_ args]
  (if (empty? args)
    (println "Usage: mgit add <filename>")
    (let [fname (first args)]
      (if (fs/exists? fname)
        (let [data (str/trim (slurp fname))
              hash (write-object data)
              index (read-index)
              new-index (assoc index fname hash)]
          (write-index new-index)
          (println (str "Added " fname " to index with hash " hash)))
        (eprintln (str "Error: " fname " does not exist."))))))

(defmethod dispatch-command "commit" [_ args]
  (if (empty? args)
    (println "Usage: mgit commit <message>")
    (let [index (read-index)]
      (if (empty? index)
        (println "Nothing to commit (index is empty).")
        (let [message (first args)
              parent (get-head-commit)
              tree (json/generate-string index)
              hash (write-object (str "tree " tree "\nparent " parent "\nmessage" message))
              current-branch (get-current-branch)]
          (if (nil? current-branch)
            (fs/write-lines head-file [hash])
            (fs/write-lines (fs/path heads-dir current-branch) [hash]))
          (println (str "Committed as " hash)))))))

(defn -main [& args]
  (when (empty? args)
    (eprintln "Usage: mgit <command> [<args>]")
    (System/exit 1))
  (let [command (first args)
        sub-args (rest args)]
    (dispatch-command command sub-args)))

(when (= *file* (System/getProperty "babashka.file"))
  (apply -main *command-line-args*))
