#!/usr/bin/env bb
(require '[babashka.fs :as fs]
         '[clojure.string :as str])
(import '[java.security MessageDigest]
        '[java.util.zip DeflaterOutputStream]
        '[java.io ByteArrayOutputStream])

(def mgit-dir-path (fs/path ".mgit"))
(def objects-dir-path (fs/path mgit-dir-path "objects"))
(def refs-dir-path (fs/path mgit-dir-path "refs"))
(def heads-dir-path (fs/path refs-dir-path "heads"))
(def head-file-path (fs/path mgit-dir-path "HEAD"))
(def index-file-path (fs/path mgit-dir-path "index"))

(defn- eprintln [& args]
  (binding [*out* *err*]
    (apply println args)))

(defn- sha1-hash [data]
  (let [digest (MessageDigest/getInstance "SHA-1")]
    (.update digest (.getBytes data))
    (let [hash-bytes (.digest digest)]
      (apply str (map #(format "%02x" %) hash-bytes)))))

(defn- compress-zlib [data]
  (let [boas (ByteArrayOutputStream.)]
    (with-open [dos (DeflaterOutputStream. boas)]
      (.write dos data))
    (.toByteArray boas)))

(defn- hash-object [data]
  (let [hash (sha1-hash data)
        obj-path (fs/path objects-dir-path hash)]
    (if (fs/exists? obj-path)
      hash
      (fs/write-bytes obj-path (compress-zlib (.getBytes data))))))

(defn- read-index []
  (if (fs/exists? index-file-path)
    (->> (fs/read-all-lines index-file-path)
         (remove str/blank?)
         (into {} (map #(let [[path hash] (str/split % #"\s+")]
                          [path hash]))))
    {}))

(defn- write-index [index]
  (fs/write-lines
   index-file-path
   (map (fn [[path hash]] (str path " " hash)) index)))

(defmulti run-command (fn [command _] command))

(defmethod run-command :default
  [command]
  (eprintln (str "Unknown command: " command))
  (System/exit 1))

(defmethod run-command "init" [_ _]
  (if (fs/exists? mgit-dir-path)
    (println (str mgit-dir-path " already exists"))
    (do
      (doseq [path [mgit-dir-path objects-dir-path refs-dir-path heads-dir-path]]
        (fs/create-dirs path))
      (fs/write-lines head-file-path ["ref: refs/heads/master\n"])
      (fs/create-file index-file-path)
      (fs/create-file (fs/path heads-dir-path "master"))
      (println (str "Initialized empty mgit repository in " mgit-dir-path)))))

(defmethod run-command "add" [_ args]
  (if (empty? args)
    (println "Usage: mgit add <filename>")
    (let [fname (first args)]
      (if (fs/exists? fname)
        (let [data (str/join "\n" (fs/read-all-lines fname))
              hash (hash-object data)
              index (read-index)
              new-index (assoc index fname hash)]
          (write-index new-index)
          (println (str "Added " fname " to index with hash " hash)))
        (eprintln (str "Error: " fname " does not exist."))))))

(defn -main [& args]
  (when (empty? args)
    (eprintln "Usage: mgit <command> [<args>]")
    (System/exit 1))
  (let [command (first args)
        sub-args (rest args)]
    (run-command command sub-args)))

(when (= *file* (System/getProperty "babashka.file"))
  (apply -main *command-line-args*))
